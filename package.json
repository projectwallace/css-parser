{
	"name": "@projectwallace/css-parser",
	"version": "0.13.5",
	"description": "High-performance CSS lexer and parser, optimized for CSS inspection and analysis",
	"author": "Bart Veneman <bart@projectwallace.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/css-parser.git"
	},
	"issues": "https://github.com/projectwallace/css-parser/issues",
	"homepage": "https://github.com/projectwallace/css-parser",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./package.json": "./package.json",
		"./tokenizer": {
			"types": "./dist/tokenize.d.mts",
			"import": "./dist/tokenize.mjs"
		},
		"./parse": {
			"types": "./dist/parse.d.mts",
			"import": "./dist/parse.mjs"
		},
		"./parse-selector": {
			"types": "./dist/parse-selector.d.mts",
			"import": "./dist/parse-selector.mjs"
		},
		"./parse-atrule-prelude": {
			"types": "./dist/parse-atrule-prelude.d.mts",
			"import": "./dist/parse-atrule-prelude.mjs"
		},
		"./parse-declaration": {
			"types": "./dist/parse-declaration.d.mts",
			"import": "./dist/parse-declaration.mjs"
		},
		"./parse-value": {
			"types": "./dist/parse-value.d.mts",
			"import": "./dist/parse-value.mjs"
		},
		"./parse-anplusb": {
			"types": "./dist/parse-anplusb.d.mts",
			"import": "./dist/parse-anplusb.mjs"
		},
		"./parse-dimension": {
			"types": "./dist/parse-dimension.d.mts",
			"import": "./dist/parse-dimension.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"test": "vitest",
		"test-coverage": "vitest --coverage",
		"test-build": "npm run build && vitest run --config vitest.config.build.ts",
		"build": "tsdown",
		"benchmark": "npm run build && node benchmark/index.ts",
		"benchmark:memory": "npm run build && node --expose-gc benchmark/memory.ts",
		"lint": "oxlint --config .oxlintrc.json",
		"check": "tsc --noEmit",
		"precommit": "npm run test -- --run; npm run lint; npm run check"
	},
	"keywords": [
		"css",
		"parser",
		"lexer",
		"tokenizer",
		"ast"
	],
	"devDependencies": {
		"@codecov/rollup-plugin": "^1.9.1",
		"@projectwallace/preset-oxlint": "^0.0.7",
		"@types/node": "^24.10.1",
		"@vitest/coverage-v8": "^4.0.8",
		"bootstrap": "^5.3.8",
		"css-tree": "^3.1.0",
		"oxlint": "^1.28.0",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"tailwindcss": "^2.2.8",
		"tinybench": "^2.9.0",
		"typescript": "^5.9.3",
		"tsdown": "^0.21.0",
		"vitest": "^4.0.8"
	}
}
